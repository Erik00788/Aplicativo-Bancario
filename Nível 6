import 'package:flutter/material.dart';
import 'package:sensors_plus/sensors_plus.dart';
import 'package:vibration/vibration.dart'; // Precisa adicionar no pubspec

class AntiFurtoSimples extends StatefulWidget {
  @override
  _AntiFurtoSimplesState createState() => _AntiFurtoSimplesState();
}

class _AntiFurtoSimplesState extends State<AntiFurtoSimplest> {
  String _registro = "Aguardando movimento...";
  bool _podeDisparar = true;

  @override
  void initState() {
    super.initState();
    accelerometerEvents.listen((event) {
      // 1. REGRA: Aparelho movimentar
      if (event.x.abs() > 8 && _podeDisparar) {
        _executarAlarme();
      }
    });
  }

  void _executarAlarme() {
    _podeDisparar = false;

    // 2. REGRA: Registrar horário
    final hora = DateTime.now().toString().substring(11, 19);

    // 3. REGRA: Vibrar dispositivo
    Vibration.vibrate(duration: 500);

    // 4. REGRA: Emitir notificação (Print para o console/log)
    print("ALERTA: Movimento às $hora");

    setState(() => _registro = "FURTO DETECTADO ÀS: $hora");

    // Reset após 10 segundos (Nível 5)
    Future.delayed(Duration(seconds: 10), () => _podeDisparar = true);
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: _podeDisparar ? Colors.white : Colors.red[100],
      body: Center(
        child: Text(_registro, style: TextStyle(fontSize: 20, fontWeight: FontWeight.bold)),
      ),
    );
  }
}
